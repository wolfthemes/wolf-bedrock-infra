# Secrets — never commit
.env

# Composer-managed WP core + vendor — reinstalled via `composer install`
web/wp/
vendor/

# Bedrock's bundled default theme — not our actual theme (submodule)
web/app/themes/twentytwentyfive/

# npm-managed — reinstalled via `npm install` (submodules have their own)
node_modules/

# Runtime-generated, not source
web/app/uploads/
web/app/cache/
log
*.sql
/sql

# WP-CLI local override
wp-cli.local.yml

# Env — only .env.example is committed
.env.*
!.env.example

# IDE / OS
.vscode/
.idea/
Thumbs.db
Desktop.ini
.DS_Store
*.swp

# Local AI tooling
.claude/
.codex/
graphify-out/
