DB_ROOT_PASSWORD=your_root_password_here
DB_NAME=wordpress
DB_USER=wp_user
DB_PASSWORD=your_password_here
DB_HOST=db

WP_ENV=development
WP_HOME=http://localhost:8080
WP_SITEURL=${WP_HOME}/wp

# Multisite (subdirectory) — flip MULTISITE to true only after running
# `wp core multisite-convert` on an already-installed single site
MULTISITE=false
DOMAIN_CURRENT_SITE=localhost:8080

CACHE_PATH='/var/www/html/web/app/cache/'

# Generate real values at https://roots.io/salts.html
AUTH_KEY=generateme
SECURE_AUTH_KEY=generateme
LOGGED_IN_KEY=generateme
NONCE_KEY=generateme
AUTH_SALT=generateme
SECURE_AUTH_SALT=generateme
LOGGED_IN_SALT=generateme
NONCE_SALT=generateme
